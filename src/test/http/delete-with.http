@baseUrl = http://localhost:8080
@accessToken = {{accessToken}}

### Delete assignment with WITH mode
DELETE {{baseUrl}}/api/timetables/{{createdTimetableId}}/assignments/{{createdAssignmentId}}?mode=WITH
Authorization: Bearer {{accessToken}}

> {%
    client.test("Delete assignment with WITH mode", function () {
        client.assert(response.status === 204, "Expected 204 No Content");
    });
%}

