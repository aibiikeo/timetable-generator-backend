@baseUrl = http://localhost:8080

### Delete lesson
DELETE {{baseUrl}}/api/timetables/{{createdTimetableId}}/lessons/{{createdLessonId}}
Authorization: Bearer {{accessToken}}

> {%
    client.test("Delete lesson", function () {
        client.assert(
            response.status === 204 || response.status === 404,
            "Expected 204 No Content or 404 Not Found"
        );
    });
%}

### Delete assignment with SIMPLE mode
DELETE {{baseUrl}}/api/timetables/{{createdTimetableId}}/assignments/{{createdAssignmentId}}?mode=SIMPLE
Authorization: Bearer {{accessToken}}

> {%
    client.test("Delete assignment with SIMPLE mode", function () {
        client.assert(
            response.status === 204 || response.status === 409,
            "Expected 204 No Content or 409 Conflict"
        );
    });
%}

