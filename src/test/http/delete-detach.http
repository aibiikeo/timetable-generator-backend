@baseUrl = http://localhost:8080

### Delete faculty with DETACH mode
DELETE {{baseUrl}}/api/faculties/{{createdFacultyId}}?mode=DETACH
Authorization: Bearer {{accessToken}}

> {%
    client.test("Delete faculty with DETACH mode", function () {
        client.assert(response.status === 204, "Expected 204 No Content");
    });
%}

### Delete department with DETACH mode
DELETE {{baseUrl}}/api/departments/{{createdDepartmentId}}?mode=DETACH
Authorization: Bearer {{accessToken}}

> {%
    client.test("Delete department with DETACH mode", function () {
        client.assert(response.status === 204 || response.status === 404, "Expected 204 No Content or 404 Not Found");
    });
%}

