### Update subject
PUT {{baseUrl}}/api/subjects/{{createdSubjectId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "name": "Updated Test Subject",
  "code": "TST 102",
  "totalHours": 4,
  "hoursPerWeek": 4,
  "majorId": {{createdMajorId}},
  "teacherIds": [{{createdTeacherId}}],
  "groupIds": [{{createdStudyGroupId}}]
}

> {%
    client.test("Update subject", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}


