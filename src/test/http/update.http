@baseUrl = http://localhost:8080
@contentType = application/json

### =========================================================
### UPDATE TESTS
### Run after auth.http and 01-create.http
### =========================================================


### Update faculty
PUT {{baseUrl}}/api/faculties/{{createdFacultyId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "name": "Updated Test Faculty"
}

> {%
    client.test("Update faculty", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}


### Update department
PUT {{baseUrl}}/api/departments/{{createdDepartmentId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "name": "Updated Test Department",
  "facultyId": {{createdFacultyId}}
}

> {%
    client.test("Update department", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}


