### Update assignment
PUT {{baseUrl}}/api/timetables/{{createdTimetableId}}/assignments/{{createdAssignmentId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "subjectId": {{createdSubjectId}},
  "teacherId": {{createdTeacherId}},
  "groupIds": [{{createdStudyGroupId}}],
  "hoursPerWeek": 4,
  "shift": "ANY",
  "roomTypeRequired": "CLASSROOM",
  "hoursSplitting": "2+2",
  "specificRoomId": null
}

> {%
    client.test("Update assignment", function () {
        client.assert(response.status === 200, "Expected 200 OK");
    });
%}


### Update lesson
PUT {{baseUrl}}/api/timetables/{{createdTimetableId}}/lessons/{{createdLessonId}}
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "assignmentId": {{createdAssignmentId}},
  "dayOfWeek": "TUESDAY",
