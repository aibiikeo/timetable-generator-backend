}

> {%
    client.test("Create lesson", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(response.body.id !== undefined, "Lesson id is missing");
    });

    client.global.set("createdLessonId", response.body.id);
%}


