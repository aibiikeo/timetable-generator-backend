### Create lunch
POST {{baseUrl}}/api/lunch
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "timetableId": {{createdTimetableId}},
  "groupId": {{createdStudyGroupId}},
  "dayOfWeek": "TUESDAY",
  "startTime": "13:15:00",
  "endTime": "13:55:00",
  "isManual": true
}

> {%
    client.test("Create lunch", function () {
        client.assert(response.status === 200 || response.status === 201, "Expected 200 OK or 201 Created");
        client.assert(response.body.id !== undefined, "Lunch id is missing");
    });

    client.global.set("createdLunchId", response.body.id);
%}


