@baseUrl = http://localhost:8080
@contentType = application/json

### =========================================================
### CREATE TEST DATA
### Run after auth.http
### =========================================================


### Create faculty
POST {{baseUrl}}/api/faculties
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "name": "Test Faculty"
}

> {%
    client.test("Create faculty", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(response.body.id !== undefined, "Faculty id is missing");
    });

    client.global.set("createdFacultyId", response.body.id);
%}


### Create department
POST {{baseUrl}}/api/departments
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "name": "Test Department",
  "facultyId": {{createdFacultyId}}
}

> {%
    client.test("Create department", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(response.body.id !== undefined, "Department id is missing");
    });

    client.global.set("createdDepartmentId", response.body.id);
%}


