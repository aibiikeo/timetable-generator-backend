### Create timetable
POST {{baseUrl}}/api/timetables
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "name": "Test Timetable",
  "academicYearStart": 2025,
  "semester": "FALL",
  "facultyId": {{createdFacultyId}},
  "generationSettings": {
    "avoidSaturday": true,
    "avoidLateLessons": true,
    "maxLessonsPerDay": 3
  }
}

> {%
    client.test("Create timetable", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(response.body.id !== undefined, "Timetable id is missing");
    });

    client.global.set("createdTimetableId", response.body.id);
%}


### Create assignment
POST {{baseUrl}}/api/timetables/{{createdTimetableId}}/assignments
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "subjectId": {{createdSubjectId}},
  "teacherId": {{createdTeacherId}},
  "groupIds": [{{createdStudyGroupId}}],
  "hoursPerWeek": 6,
  "shift": "ANY",
  "roomTypeRequired": "CLASSROOM",
  "hoursSplitting": "2+2+2",
  "specificRoomId": null
}

> {%
    client.test("Create assignment", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(response.body.id !== undefined, "Assignment id is missing");
    });

    client.global.set("createdAssignmentId", response.body.id);
%}


### Create lesson
POST {{baseUrl}}/api/timetables/{{createdTimetableId}}/lessons
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

