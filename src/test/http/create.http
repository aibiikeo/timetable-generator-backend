### Create subject
POST {{baseUrl}}/api/subjects
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "name": "Test Subject",
  "code": "TST 101",
  "totalHours": 6,
  "hoursPerWeek": 6,
  "majorId": {{createdMajorId}},
  "teacherIds": [{{createdTeacherId}}],
  "groupIds": [{{createdStudyGroupId}}]
}

> {%
    client.test("Create subject", function () {
        client.assert(response.status === 201, "Expected 201 Created");
        client.assert(response.body.id !== undefined, "Subject id is missing");
    });

    client.global.set("createdSubjectId", response.body.id);
%}


