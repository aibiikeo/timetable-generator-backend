@baseUrl = http://localhost:8080
@contentType = application/json

### =========================================================
### ERROR TESTS
### Saved into ./errors/
### Before running:
### 1. Run auth.http
### 2. Make sure {{accessToken}} exists
### 3. Create folder src/test/http/errors
### =========================================================


### ERROR 001: invalid login
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "email": "wrong@university.kg",
  "password": "wrong-password"
}

> {%
    client.test("ERROR 001 - invalid login", function () {
        client.assert(response.status === 401, "Expected 401 Unauthorized");
    });
%}

>>! ./errors/001-invalid-login.json


### ERROR 002: get non-existing faculty
GET {{baseUrl}}/api/faculties/999999
Authorization: Bearer {{accessToken}}

> {%
    client.test("ERROR 002 - faculty not found", function () {
        client.assert(response.status === 404, "Expected 404 Not Found");
    });
%}

>>! ./errors/002-faculty-not-found.json


### ERROR 003: duplicate faculty name
POST {{baseUrl}}/api/faculties
Authorization: Bearer {{accessToken}}
Content-Type: {{contentType}}

{
  "name": "Faculty of Engineering and Informatics"
}

> {%
    client.test("ERROR 003 - duplicate faculty name", function () {
        client.assert(
            response.status === 400 || response.status === 409,
            "Expected 400 Bad Request or 409 Conflict"
        );
    });
%}

>>! ./errors/003-duplicate-faculty.json


